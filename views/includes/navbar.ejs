<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500&display=swap');

  .wl-navbar {
    background: #0f0f0f;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    position: sticky;
    top: 0;
    z-index: 1000;
    font-family: 'DM Sans', sans-serif;
  }

  .wl-left { display: flex; align-items: center; gap: 1.5rem; }

  .wl-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: #fe424d !important;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .wl-explore {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .wl-explore:hover { color: #fff; }

  .wl-center {
    flex: 1;
    display: flex;
    justify-content: center;
    padding: 0 1.5rem;
  }

  .wl-search-wrap {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    overflow: hidden;
    max-width: 320px;
    width: 100%;
    transition: border-color 0.2s, background 0.2s;
  }
  .wl-search-wrap:focus-within {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(254, 66, 77, 0.5);
  }
  .wl-search-wrap input {
    background: transparent;
    border: none;
    outline: none;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    padding: 0.55rem 1rem;
    flex: 1;
  }
  .wl-search-wrap input::placeholder { color: rgba(255, 255, 255, 0.3); }

  .wl-search-btn {
    background: #fe424d !important;
    border: none !important;
    color: #fff !important;
    padding: 0.45rem 1rem !important;
    border-radius: 100px !important;
    margin: 4px !important;
    font-size: 0.78rem;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .wl-search-btn:hover { background: #e0333e !important; }

  .wl-right { display: flex; align-items: center; gap: 0.2rem; }

  .wl-link {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.4rem 0.8rem;
    border-radius: 100px;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .wl-link:hover { background: rgba(255, 255, 255, 0.07); color: #fff; }
  .wl-link.outline { border: 1px solid rgba(255, 255, 255, 0.18); color: #fff; }
  .wl-link.outline:hover { background: rgba(255, 255, 255, 0.1); }
  .wl-link.primary { background: #fe424d; color: #fff; }
  .wl-link.primary:hover { background: #e0333e; }

  /* ── Hamburger Button ── */
  .wl-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .wl-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: rgba(255, 255, 255, 0.7);
    border-radius: 2px;
    transition: all 0.3s;
  }
  .wl-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .wl-hamburger.open span:nth-child(2) { opacity: 0; }
  .wl-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile Drawer ── */
  .wl-drawer {
    display: none;
    flex-direction: column;
    background: #0f0f0f;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1rem 1.5rem 1.5rem;
    gap: 0.4rem;
    position: sticky;
    top: 64px;
    z-index: 999;
  }
  .wl-drawer.open { display: flex; }

  .wl-drawer .wl-search-wrap {
    max-width: 100%;
    margin-bottom: 0.5rem;
  }
  .wl-drawer .wl-link {
    display: block;
    font-size: 0.9rem;
    padding: 0.6rem 0.8rem;
  }
  .wl-drawer .wl-link.outline,
  .wl-drawer .wl-link.primary {
    text-align: center;
    margin-top: 0.2rem;
  }

  /* ── Breakpoints ── */
  @media (max-width: 768px) {
    .wl-center { display: none; }
    .wl-explore { display: none; }
    .wl-right { display: none; }
    .wl-hamburger { display: flex; }
  }
</style>

<nav class="wl-navbar">
  <div class="wl-left">
  <a class="wl-logo" href="/listings">
 <i class="fa-brands fa-airbnb fa-xl"></i></a>
    <a class="wl-explore" href="/listings">Explore</a>
  </div>

  <div class="wl-center">
    <form class="wl-search-wrap" role="search">
      <input type="search" placeholder="Search destination..." aria-label="Search" />
      <button class="wl-search-btn" type="submit">
        <i class="fa-solid fa-magnifying-glass"></i> Search
      </button>
    </form>
  </div>

  <div class="wl-right">
    <a class="wl-link" href="/listings/new">Airbnb your home</a>
    <% if (!curruser) { %>
      <a class="wl-link outline" href="/signup">Sign up</a>
      <a class="wl-link primary" href="/login">Log in</a>
    <% } %>
    <% if (curruser) { %>
      <a class="wl-link outline" href="/logout">Log out</a>
    <% } %>
    <a class="wl-link primary" href="/contact">Contact us</a>
  </div>

  <!-- Hamburger -->
  <button class="wl-hamburger" id="wl-ham" onclick="toggleDrawer()">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile Drawer -->
<div class="wl-drawer" id="wl-drawer">
  <form class="wl-search-wrap" role="search">
    <input type="search" placeholder="Search destination..." aria-label="Search" />
    <button class="wl-search-btn" type="submit">
      <i class="fa-solid fa-magnifying-glass"></i> Search
    </button>
  </form>
  <a class="wl-link" href="/listings">Explore</a>
  <a class="wl-link" href="/listings/new">Airbnb your home</a>
  <% if (!curruser) { %>
    <a class="wl-link outline" href="/signup">Sign up</a>
    <a class="wl-link primary" href="/login">Log in</a>
  <% } %>
  <% if (curruser) { %>
    <a class="wl-link outline" href="/logout">Log out</a>
  <% } %>
</div>

<script>
  function toggleDrawer() {
    const drawer = document.getElementById('wl-drawer');
    const ham = document.getElementById('wl-ham');
    drawer.classList.toggle('open');
    ham.classList.toggle('open');
  }
</script>

