<% layout("/layouts/boilerplate")%>

<style>
  /* ── HERO ── */
  .wl-hero {
    background: #080808;
    height: 380px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 3rem 3.5rem 2.8rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	border-radius:20px;
    position: relative;
    overflow: hidden;
  }
  .wl-hero::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: rgba(254, 66, 77, 0.04);
  }
  .wl-hero::after {
    content: '';
    position: absolute;
    bottom: -120px; left: 30%;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: rgba(254, 66, 77, 0.03);
  }
  .wl-hero-content { position: relative; z-index: 1; }
  .wl-hero-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: #fe424d; margin-bottom: 0.7rem; font-weight: 400;
    display: flex; align-items: center; gap: 10px;
  }
  .wl-hero-eyebrow::after {
    content: ''; display: block;
    width: 32px; height: 1px; background: #fe424d; opacity: 0.6;
  }
  .wl-hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.8rem; font-weight: 600; color: #fff;
    line-height: 1.05; letter-spacing: -1px;
  }
  .wl-hero-title em { font-style: italic; color: rgba(255, 255, 255, 0.35); }
  .wl-hero-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem; color: rgba(255, 255, 255, 0.28);
    margin-top: 0.9rem; font-weight: 300; letter-spacing: 0.04em;
    display: flex; align-items: center; gap: 8px;
  }
  .wl-hero-sub::before {
    content: ''; display: block;
    width: 20px; height: 1px; background: rgba(255, 255, 255, 0.15);
  }
  .wl-hero-stats {
    position: relative; z-index: 1;
    display: flex; gap: 2.5rem; align-items: center; align-self: flex-end;
  }
  .wl-stat { text-align: right; }
  .wl-stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem; font-weight: 600; color: #fff; line-height: 1;
  }
  .wl-stat-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.58rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(255, 255, 255, 0.2); margin-top: 5px;
  }
  .wl-stat-divider { width: 1px; height: 40px; background: rgba(255, 255, 255, 0.07); }

  /* ── FILTERS BAR ── */
  #filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.2rem;
    padding: 1rem 0 1.2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    margin-bottom: 1.5rem;
  }
  .filter {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 0.5rem 1rem; border-radius: 12px; cursor: pointer; opacity: 0.45;
    transition: opacity 0.2s, background 0.2s, transform 0.2s;
    text-decoration: none !important; color: #fff !important;
    border-bottom: 2px solid transparent;
  }
  .filter:hover {
    opacity: 1; background: rgba(255, 255, 255, 0.05);
    transform: translateY(-2px); color: #fff !important;
  }
  .filter.active { opacity: 1; border-bottom: 2px solid #fe424d; }
  .filter i { font-size: 1.3rem; color: #fff; }
  .filter p { font-size: 0.72rem; color: rgba(255,255,255,0.8); white-space: nowrap; margin: 0; }

  /* ── TAX TOGGLE ── */
  .tax-toggle {
    margin-left: auto; display: flex; align-items: center;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px; padding: 0.5rem 1rem; gap: 0.6rem; white-space: nowrap;
  }
  .tax-toggle label { font-size: 0.78rem; color: rgba(255,255,255,0.45); cursor: pointer; }
  .form-check-input:checked { background-color: #fe424d !important; border-color: #fe424d !important; }
  .form-check-input:focus { box-shadow: 0 0 0 3px rgba(254,66,77,0.2) !important; }

  /* ── LISTING CARDS ── */
  .listing-link { text-decoration: none !important; color: inherit !important; display: block; }
  .listing-card {
    background: #1a1a1a !important; border: 1px solid rgba(255,255,255,0.07) !important;
    border-radius: 16px !important; overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease; cursor: pointer;
  }
  .listing-card:hover { transform: translateY(-5px); border-color: rgba(254,66,77,0.35) !important; }
  .listing-card .card-img-top { height: 200px; object-fit: cover; transition: transform 0.4s ease; }
  .listing-card:hover .card-img-top { transform: scale(1.05); }
  .listing-card .card-body { padding: 0.9rem 1rem 1rem; }
  .listing-card .card-text { font-size: 0.85rem; color: rgba(255,255,255,0.5); margin: 0; line-height: 1.8; }
  .listing-card .card-text b {
    font-family: 'Playfair Display', serif; font-size: 0.95rem;
    color: #fff !important; display: block; white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis; margin-bottom: 4px;
  }
  .tax-info { display: none; color: rgba(255,255,255,0.3); font-size: 0.75rem; font-style: normal; }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .wl-hero { height: auto; padding: 2rem 1.5rem; flex-direction: column; gap: 2rem; align-items: flex-start; }
    .wl-hero-title { font-size: 2.6rem; }
    .wl-hero-stats { display: none; }
    .tax-toggle { margin-left: 0; margin-top: 0.5rem; width: 100%; justify-content: space-between; }
  }
</style>

<!-- HERO -->
<div class="wl-hero">
  <div class="wl-hero-content">
    <div class="wl-hero-eyebrow">Curated escapes</div>
    <div class="wl-hero-title">Find your<br><em>perfect stay</em></div>
    <div class="wl-hero-sub">3,200+ handpicked properties across India</div>
  </div>
  <div class="wl-hero-stats">
    <div class="wl-stat"><div class="wl-stat-num">3.2K+</div><div class="wl-stat-label">Properties</div></div>
    <div class="wl-stat-divider"></div>
    <div class="wl-stat"><div class="wl-stat-num">98%</div><div class="wl-stat-label">Happy guests</div></div>
    <div class="wl-stat-divider"></div>
    <div class="wl-stat"><div class="wl-stat-num">4.9★</div><div class="wl-stat-label">Avg rating</div></div>
  </div>
</div>

<!-- FILTERS -->
<div id="filters">
  <a class="filter" href="/listings/category/Trending"><i class="fa-solid fa-fire"></i><p>Trending</p></a>
  <a class="filter" href="/listings/category/Rooms"><i class="fa-solid fa-bed"></i><p>Rooms</p></a>
  <a class="filter" href="/listings/category/Iconic cities"><i class="fa-solid fa-mountain-city"></i><p>Iconic Cities</p></a>
  <a class="filter" href="/listings/category/Mountains"><i class="fa-solid fa-mountain"></i><p>Mountains</p></a>
  <a class="filter" href="/listings/category/Castles"><i class="fa-solid fa-fort-awesome"></i><p>Castles</p></a>
  <a class="filter" href="/listings/category/Amazing Pools"><i class="fa-solid fa-person-swimming"></i><p>Amazing Pools</p></a>
  <a class="filter" href="/listings/category/Camping"><i class="fa-solid fa-campground"></i><p>Camping</p></a>
  <a class="filter" href="/listings/category/Farms"><i class="fa-solid fa-seedling"></i><p>Farms</p></a>
  <a class="filter" href="/listings/category/Arctic"><i class="fa-solid fa-snowflake"></i><p>Arctic</p></a>
  <a class="filter" href="/listings/category/Domes"><i class="fa-solid fa-igloo"></i><p>Domes</p></a>
  <a class="filter" href="/listings/category/Boats"><i class="fa-solid fa-ship"></i><p>Boats</p></a>
  <div class="tax-toggle">
    <div class="form-check form-switch mb-0">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
  </div>
</div>

<!-- CARDS -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3 g-4">
  <% for(let list of all_listing){ %>
    <div class="col">
      <a href="/listings/<%= list._id %>" class="listing-link">
        <div class="card listing-card">
          <img src="<%= list.image.url %>" class="card-img-top" alt="listing image">
          <div class="card-body">
            <p class="card-text">
              <b><%= list.title %></b>
              &#8377;<%= list.price.toLocaleString("en-IN") %>/night
              <i class="tax-info">&nbsp;+18% GST</i>
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>

<script>
  let taxswitch = document.getElementById("switchCheckDefault");
  taxswitch.addEventListener("click", () => {
    let taxinfo = document.getElementsByClassName("tax-info");
    for (let info of taxinfo) {
      info.style.display = (info.style.display != "inline") ? "inline" : "none";
    }
  });

  const filters = document.querySelectorAll('.filter');
  const currentPath = window.location.pathname;
  filters.forEach(f => {
    if (f.getAttribute('href') === currentPath) {
      f.classList.add('active');
    }
  });
</script>