<% layout("/layouts/boilerplate")%>

	<div class="row mt-3">
		<div class="col-8 offset-2">


			<h3>Edit a List</h3>
			<form method="post" action="/listings/<%=list._id%>?_method=PUT" enctype="multipart/form-data">
				<div>
					<label for="title" class="form-label">Title</label>
					<input name="list[title]" value="<%=list.title%>" type="text" class="form-control">

				</div>
				<div>
					<label for="description" class="form-label">Description</label>
					<textarea name="list[description]" class="form-control"><%=list.description%> </textarea>
				</div>

				<div class="mb-3" height="50" width="50">
					<i>original Listing image</i><br />
					<img src="<%=originalimage%>" />
				</div>
				<div>
					<label for="image" class="form-label">Upload Image</label>
					<input name="list[image]" placeholder="enter image or file" type="file" class="form-control">
				</div>
				<div class="row">
					<div class="mb-3 col-md-4">

						<label for="price" class="form-label">Price</label>
						<input name="list[price]" value="<%=list.price%>" type="number" class="form-control">
					</div>

					<div class="mb-3 col-md-8">
						<label for="country" class="form-label">Country</label>
						<input name="list[country]" value="<%=list.country%>" type="text" class="form-control">
					</div>
				</div>

				<div>

					<label for="location" class="form-label">Location</label>
					<input name="list[location]" value="<%=list.location%>" type="text" class="form-control">
				</div>

				<div class="mb-3">
					<label for="category" class="form-label">Category</label>
					<select name="list[category]" class="form-select">
						<option value="Trending" <%=list.category==="Trending" ? "selected" : "" %>>Trending</option>
						<option value="Rooms" <%=list.category==="Rooms" ? "selected" : "" %>>Rooms</option>
						<option value="Iconic cities" <%=list.category==="Iconic cities" ? "selected" : "" %>>Iconic
							cities</option>
						<option value="Mountains" <%=list.category==="Mountains" ? "selected" : "" %>>Mountains</option>
						<option value="Castles" <%=list.category==="Castles" ? "selected" : "" %>>Castles</option>
						<option value="Amazing pools" <%=list.category==="Amazing pools" ? "selected" : "" %>>Amazing
							pools</option>
						<option value="Camping" <%=list.category==="Camping" ? "selected" : "" %>>Camping</option>
						<option value="Farms" <%=list.category==="Farms" ? "selected" : "" %>>Farms</option>
						<option value="Arctic" <%=list.category==="Arctic" ? "selected" : "" %>>Arctic</option>
						<option value="Beachfront" <%=list.category==="Beachfront" ? "selected" : "" %>>Beachfront
						</option>
					</select>
				</div>
				<button class="btn btn-dark edit-btn mt-3 edit-btn">Edit</button>
			</form>
		</div>
	</div>