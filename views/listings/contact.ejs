<!-- Toast -->
<div id="toast"></div>

<script>
/* VISITOR COUNTER */
(function(){
  const k='wl_c4', n=parseInt(localStorage.getItem(k)||'0',10)+1;
  localStorage.setItem(k,n);
  const el=document.getElementById('vCount');
  let c=0, step=Math.max(1,Math.floor(n/50));
  const t=setInterval(()=>{ c=Math.min(c+step,n); el.textContent=c.toLocaleString(); if(c>=n)clearInterval(t); },22);
})();

/* CHAR COUNTER */
const mgEl=document.getElementById('mg'), ccEl=document.getElementById('cc');
mgEl.addEventListener('input',()=>{
  const l=mgEl.value.length; ccEl.textContent=l+' / 500'; ccEl.classList.toggle('warn',l>440);
});

/* TOAST */
function toast(msg,type='ok'){
  const t=document.getElementById('toast');
  t.innerHTML=`<i class="fa-solid fa-${type==='ok'?'circle-check':'triangle-exclamation'}"></i>${msg}`;
  t.className='show '+type; clearTimeout(t._r); t._r=setTimeout(()=>t.className='',4500);
}

/* FORM */
document.getElementById('cForm').addEventListener('submit',function(e){
  e.preventDefault();
  const rules=[
    {id:'nm',ok:v=>v.trim().length>=2},
    {id:'em',ok:v=>/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)},
    {id:'sb',ok:v=>v!==''},
    {id:'mg',ok:v=>v.trim().length>=10},
  ];
  let valid=true;
  rules.forEach(({id,ok})=>{
    const el=document.getElementById(id), pass=ok(el.value);
    el.classList.toggle('err',!pass);
    if(!pass){ valid=false; el.addEventListener('input',()=>el.classList.remove('err'),{once:true}); }
  });
  if(!valid){ toast('Please fill in all required fields correctly.','bad'); return; }

  const btn=document.getElementById('sbBtn');
  btn.disabled=true;
  btn.innerHTML='<i class="fa-solid fa-spinner fa-spin"></i><span>Sending…</span>';
  setTimeout(()=>{
    const name=document.getElementById('nm').value.trim().split(' ')[0];
    toast(`Message sent! We'll reply within 24 hours, ${name} ✈️`,'ok');
    this.reset(); ccEl.textContent='0 / 500';
    btn.innerHTML='<i class="fa-solid fa-circle-check"></i><span>Message Sent!</span>';
    btn.disabled=false;
    setTimeout(()=>btn.innerHTML='<i class="fa-solid fa-paper-plane"></i><span>Send Message</span>',3000);
  },1700);
});

/* STAT COUNTERS */
const io=new IntersectionObserver(entries=>entries.forEach(en=>{
  if(!en.isIntersecting)return;
  const el=en.target, n=parseInt(el.dataset.n), s=el.dataset.s||'';
  let c=0, step=Math.max(1,n/60);
  const t=setInterval(()=>{ c=Math.min(c+step,n); el.innerHTML=Math.floor(c).toLocaleString()+`<sup>${s}</sup>`; if(c>=n)clearInterval(t); },18);
  io.unobserve(el);
}),{threshold:.5});
document.querySelectorAll('.s-val[data-n]').forEach(el=>io.observe(el));
</script>